# =============================================================================
#  TDP Gestión — variables de entorno. En COOLIFY van como Environment/Shared
#  Variables del recurso — este fichero es solo la REFERENCIA. Secretos NUNCA
#  en el repo.
# =============================================================================

# --- App ---
# El dominio público NO va aquí: se fija en el campo "Domains for app" de la UI
# de Coolify (p. ej. gestion.tallerdelpatinete.es). Coolify enruta por Traefik
# al puerto 3000 que el servicio expone en el docker-compose.

# BD propia de la app: la PostgreSQL GESTIONADA de UpCloud. Crea en ella el
# usuario 'tdp' y la BD 'tdp_gestion' (owner tdp) y usa el host/puerto del
# panel de UpCloud.
#
# TLS (importante): node-postgres trata sslmode=require como verify-full, y la
# gestionada usa una CA privada que NO está en el almacén del contenedor. Elige:
#   (A) Recomendado: DATABASE_CA_CERT con la CA (panel UpCloud → CA certificate)
#       y sslmode=require en la URL → verificación completa contra esa CA.
#   (B) Rápido: sslmode=no-verify en la URL (cifra pero no verifica el cert).
# Con sslmode=require SIN CA la conexión FALLA (self-signed certificate).
DATABASE_URL=postgres://tdp:PASS@HOST.upclouddatabases.com:11569/tdp_gestion?sslmode=require
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Solo para desarrollo local con el Postgres del compose
# (docker compose --profile local-db up; DATABASE_URL=postgres://tdp:PASS@db:5432/tdp_gestion):
POSTGRES_USER=tdp
POSTGRES_PASSWORD=
POSTGRES_DB=tdp_gestion

# Firma de sesiones (genera con: openssl rand -base64 48)
AUTH_SECRET=

# ADMIN inicial: se crea solo si la tabla de usuarios está vacía
ADMIN_EMAIL=central@tallerdelpatinete.es
ADMIN_PASSWORD=

# --- UpCloud (sub-cuenta de API con mínimo privilegio — la misma que usa tofu) ---
UPCLOUD_USERNAME=
UPCLOUD_PASSWORD=

# --- OpenTofu: estado remoto en Postgres (docs/82 de tdp-tienda-infra) ---
# OJO: el backend pg de tofu usa lib/pq (Go), que NO admite sslmode=no-verify
# (eso es de node-postgres, para DATABASE_URL). Aquí el "cifra sin verificar" es
# sslmode=require. La app normaliza no-verify→require por si acaso.
# PG_CONN_STR=postgres://tofu:PASS@HOST:PORT/tofu_state?sslmode=require
PG_CONN_STR=

# --- GitHub (fine-grained PAT):
#   tdp-app-wordpress-prod → contents rw + pull requests rw
#   tdp-tienda-infra       → contents ro
#   org packages           → read:packages (tags de ghcr)
GITHUB_TOKEN=
GITHUB_ORG=infra-tdp
WEB_REPO=tdp-app-wordpress-prod
INFRA_REPO=tdp-tienda-infra
GHCR_IMAGE=ghcr.io/infra-tdp/tdp-app-wordpress-prod

# --- Coolify API (Keys & Tokens → API tokens, permisos de escritura) ---
# Origen de la API de Coolify, p. ej. http://10.0.0.16:8000 (sin /api/v1).
# NO la llames COOLIFY_URL: es una variable reservada que Coolify pisa con la URL de la app.
COOLIFY_API_URL=
COOLIFY_TOKEN=
# Proyecto/entorno/server donde se crean los stagings:
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT_NAME=staging
# Sources → GitHub App (la misma con la que se despliega la web) → uuid
COOLIFY_GITHUB_APP_UUID=

# --- Backups de la BD de la web (UpCloud Object Storage, ver backup-db.sh) ---
S3_ENDPOINT=
S3_REGION=europe-1
S3_BUCKET_BACKUPS=
S3_BACKUP_ACCESS_KEY=
S3_BACKUP_SECRET_KEY=
S3_BACKUPS_PREFIX=db/
# Passphrase GPG de los dumps (la misma de BACKUP_GPG_PASSPHRASE en el server)
BACKUP_GPG_PASSPHRASE=

# --- Media S3 de la web (los stagings reutilizan el bucket de media) ---
S3_BUCKET_MEDIA=
TDP_CDN_DOMAIN=

# --- Staging ---
# Apex de la zona. El entorno se publica en UN SOLO nivel: <slug>-staging.<apex>
# (p. ej. central-tdp-e9e1-staging.tallerdelpatinete.es) para que lo cubra el
# certificado Universal SSL gratuito *.tallerdelpatinete.es. Un segundo nivel
# (*.staging.tallerdelpatinete.es) exigiría Advanced Certificate Manager (pago).
STAGING_DOMAIN_BASE=tallerdelpatinete.es
STAGING_DOMAIN_SUFFIX=-staging
# Host (IP/DNS) al que los devs conectan por SSH para el devbox
STAGING_DEVBOX_HOST=
STAGING_DEVBOX_PORT_BASE=22000
# Token de solo lectura/escritura acotado al repo web para el clon dentro del devbox
STAGING_GIT_TOKEN=
STAGING_COMPOSE_LOCATION=/docker-compose.staging.yaml
# Compose para "construir desde la rama" (build del Dockerfile del repo)
STAGING_COMPOSE_BUILD_LOCATION=/docker-compose.staging-build.yaml
# Plugin(s) de offload/CDN a desactivar en staging (paths relativos a wp-content/
# plugins, coma-separado) → las subidas nuevas del dev quedan locales, prod intacta.
# Vacío = el mu-plugin prueba slugs comunes. Ej: amazon-s3-and-cloudfront/wordpress-s3.php
STAGING_DISABLE_PLUGINS=

# --- Enrutado dinámico por Cloudflare Tunnel (opcional) ---
# El entorno vive en el nodo que elige el dev, así que la app crea/borra por API
# la ruta <slug>-staging.<apex> → http://<ip-nodo>:80 (Traefik del nodo). Con esto
# no necesitas wildcard multinivel (que exigiría ACM de pago).
#   Token con permisos: Account·Cloudflare Tunnel:Edit + Zone·DNS:Edit
CF_API_TOKEN=
CF_ACCOUNT_ID=
# UUID del Tunnel cuyo cloudflared alcanza AMBOS nodos por IP privada (10.0.0.x)
CF_TUNNEL_ID=
# Zona de tallerdelpatinete.es (para crear el CNAME por entorno → el túnel)
CF_ZONE_ID=
# IP privada del nodo: por defecto se resuelve SOLA a partir del servidor de
# Coolify elegido (su IP privada directa o, vía UpCloud, la de su interfaz SDN),
# así que al añadir un nodo nuevo no hay que tocar nada.
#   UPCLOUD_PRIVATE_NETWORK  (opcional) uuid de la red SDN a usar si el nodo tiene
#                            varias interfaces privadas.
#   STAGING_NODE_IPS         (opcional) override manual JSON {serverUuid: ip}.
UPCLOUD_PRIVATE_NETWORK=
STAGING_NODE_IPS=

# --- Monitores creados automáticamente al arrancar (Nombre|URL, separados por comas) ---
MONITOR_DEFAULTS=Web prod|https://tallerdelpatinete.es,Preprod|https://preprod.tallerdelpatinete.es

# --- Asistente IA ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Agente de tareas WhatsApp (repo tdp-agente-tareas, módulo /agente) ---
# URL del servicio del agente. Si comparte la red 'coolify', vale el nombre
# interno del servicio (http://agente:3100); si no, su dominio público.
TASK_AGENT_URL=
# El MISMO valor que AGENT_ADMIN_TOKEN en el agente (openssl rand -hex 24)
TASK_AGENT_TOKEN=
